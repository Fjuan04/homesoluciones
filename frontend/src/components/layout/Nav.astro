---
import Button from '../ui/Button.astro';
---

<nav id="main-nav" class=" fixed top-0 left-0 w-full z-[100] transition-all duration-500 py-6 border-b border-white/0">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 flex items-center justify-between">
    <a href="/" class="flex items-center gap-4 transition-transform duration-300 hover:scale-[1.02]">
      <img src="/logo.png" alt="Logo" class="h-12 md:h-14 w-auto object-contain" />
      <span class="font-sans text-2xl md:text-3xl font-bold tracking-tight uppercase">
        Home<span class="text-primary">soluciones</span>
      </span>
      <span class="sr-only">Home Soluciones</span>
    </a>

    <ul class="hidden lg:flex items-center gap-10">
      <li><a href="#inicio" class="text-xs uppercase tracking-[0.2em] hover:text-primary transition-colors duration-300">Inicio</a></li>
      <li><a href="#servicios" class="text-xs uppercase tracking-[0.2em] hover:text-primary transition-colors duration-300">Servicios</a></li>
      <li><a href="#ambientes" class="text-xs uppercase tracking-[0.2em] hover:text-primary transition-colors duration-300">Ambientes</a></li>
      <li><a href="#proceso" class="text-xs uppercase tracking-[0.2em] hover:text-primary transition-colors duration-300">Proceso</a></li>
      <li><a href="#blog" class="text-xs uppercase tracking-[0.2em] hover:text-primary transition-colors duration-300">Blog</a></li>
    </ul>

    <div class="flex items-center gap-6">
      <a href="#contacto" class="hidden sm:block text-xs uppercase tracking-[0.2em] hover:text-primary transition-colors duration-300 mr-4">Contacto</a>
      <Button variant="primary" size="sm" href="#presupuesto" className="hidden md:flex">
        Presupuesto
      </Button>
      
      <!-- Mobile menu toggle -->
      <button class="lg:hidden flex flex-col gap-1.5 p-2 group" aria-label="Menu">
        <span class="w-6 h-0.5 bg-light-bg group-hover:bg-primary transition-colors"></span>
        <span class="w-6 h-0.5 bg-light-bg group-hover:bg-primary transition-colors"></span>
        <span class="w-4 h-0.5 bg-light-bg group-hover:bg-primary transition-colors self-end"></span>
      </button>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('main-nav');
  
  const handleScroll = () => {
    if (window.scrollY > 60) {
      nav?.classList.add('bg-dark-bg/80', 'backdrop-blur-xl', 'py-4', 'border-white/10');
      nav?.classList.remove('py-6', 'border-white/0');
    } else {
      nav?.classList.remove('bg-dark-bg/80', 'backdrop-blur-xl', 'py-4', 'border-white/10');
      nav?.classList.add('py-6', 'border-white/0');
    }
  };

  window.addEventListener('scroll', handleScroll);
  // Initial check
  handleScroll();
</script>

<style>
  /* Base styles for the nav links */
  ul a {
    position: relative;
  }
  
  ul a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 1px;
    background-color: var(--color-primary);
    transition: width 0.3s ease;
  }

  ul a:hover::after {
    width: 100%;
  }
</style>
