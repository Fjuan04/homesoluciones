---
import Button from '../ui/Button.astro';
---

<header class="fixed top-0 left-0 w-full z-50 transition-all duration-300 border-b border-white/10 bg-white/50 dark:bg-black/50 backdrop-blur-md">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    <div class="flex items-center gap-2">
      <div class="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center">
        <span class="text-white font-bold text-xl">H</span>
      </div>
      <span class="text-xl font-bold tracking-tight">HomeSoluciones</span>
    </div>

    <nav class="hidden md:flex items-center gap-8 text-sm font-medium opacity-80">
      <a href="#" class="hover:text-indigo-600 transition-colors">Servicios</a>
      <a href="#" class="hover:text-indigo-600 transition-colors">Empresa</a>
      <a href="#" class="hover:text-indigo-600 transition-colors">Proyectos</a>
      <a href="#" class="hover:text-indigo-600 transition-colors">Contacto</a>
    </nav>

    <div class="flex items-center gap-4">
      <Button variant="outline" size="sm">Entrar</Button>
      <Button variant="primary" size="sm">Empezar</Button>
    </div>
  </div>
</header>
