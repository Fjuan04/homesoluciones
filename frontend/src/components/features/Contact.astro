---
import Button from '../ui/Button.astro';
---

<section id="contacto" class="py-32 bg-dark-bg">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 grid grid-cols-1 lg:grid-cols-2 gap-24">
    
    <!-- Contact Info -->
    <div class="space-y-12 reveal">
      <div class="space-y-6">
        <h2 class="text-5xl md:text-7xl font-medium">Hablemos de <br/> <span class="italic text-primary">tu proyecto</span></h2>
        <p class="text-light-bg/60 text-lg leading-relaxed max-w-md">
          ¿Listo para transformar tu espacio? Nuestro equipo de expertos está a tu disposición para asesorarte en cada paso.
        </p>
      </div>

      <div class="space-y-8">
        <div class="flex items-start gap-6">
          <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-widest text-light-bg/40 mb-1">Email</p>
            <p class="text-lg">proyectos@homesoluciones.com</p>
          </div>
        </div>

        <div class="flex items-start gap-6">
          <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-primary">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-widest text-light-bg/40 mb-1">Teléfono</p>
            <p class="text-lg">+52 (55) 1234 5678</p>
          </div>
        </div>

        <div class="flex items-start gap-6">
          <div class="w-10 h-10 rounded-full border border-white/10 flex items-center justify-center text-primary">
             <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <div>
            <p class="text-[10px] uppercase tracking-widest text-light-bg/40 mb-1">Ubicación</p>
            <p class="text-lg">Polanco, Ciudad de México</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact Form -->
    <div class="bg-dark-section p-8 md:p-12 border border-white/5 reveal">
      <form class="space-y-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="space-y-2 relative">
            <label for="name" class="text-[10px] uppercase tracking-widest text-light-bg/40">Nombre Completo</label>
            <input type="text" id="name" name="name" class="w-full bg-transparent border-b border-white/10 py-3 text-light-bg focus:border-primary focus:outline-none transition-colors" placeholder="Tu nombre" />
          </div>
          <div class="space-y-2 relative">
            <label for="email" class="text-[10px] uppercase tracking-widest text-light-bg/40">Email Corporativo</label>
            <input type="email" id="email" name="email" class="w-full bg-transparent border-b border-white/10 py-3 text-light-bg focus:border-primary focus:outline-none transition-colors" placeholder="email@ejemplo.com" />
          </div>
        </div>

        <div class="space-y-2 relative">
          <label for="type" class="text-[10px] uppercase tracking-widest text-light-bg/40">Tipo de Proyecto</label>
          <select id="type" name="type" class="w-full bg-transparent border-b border-white/10 py-3 text-light-bg focus:border-primary focus:outline-none transition-colors appearance-none">
            <option value="residencial" class="bg-dark-section">Remodelación Residencial</option>
            <option value="comercial" class="bg-dark-section">Diseño Comercial</option>
            <option value="arquitectura" class="bg-dark-section">Arquitectura Interior</option>
          </select>
        </div>

        <div class="space-y-2 relative">
          <label for="message" class="text-[10px] uppercase tracking-widest text-light-bg/40">Descripción del Proyecto</label>
          <textarea id="message" name="message" rows="4" class="w-full bg-transparent border-b border-white/10 py-3 text-light-bg focus:border-primary focus:outline-none transition-colors resize-none" placeholder="Cuéntanos más..."></textarea>
        </div>

        <div class="pt-6">
          <Button variant="primary" size="lg" className="w-full">
            Enviar Mensaje
          </Button>
        </div>
      </form>
    </div>

  </div>
</section>
