---
import Button from '../ui/Button.astro';

const API_URL = import.meta.env.API_URL || 'http://localhost:3000/api';

let featuredProject = null;

try {
  const response = await fetch(`${API_URL}/projects/featured`);
  if (response.ok) {
    featuredProject = await response.json();
  }
} catch (error) {
  console.error("Error fetching featured project:", error);
}

// Fallback data
const fallbackHero = {
  title: "Residencia Bosques",
  location: "Barrio Bosques",
  city: "Manizales",
  country: "Colombia",
  image: "/images/hero.webp"
};

const displayProject = featuredProject || fallbackHero;

const getImageUrl = (url: string) => {
  if (!url) return '';
  if (url.startsWith('http')) return url;
  const baseUrl = API_URL.replace('/api', '');
  return `${baseUrl}${url}`;
};
---

<section id="inicio" class="relative min-h-screen flex items-center pt-24 overflow-hidden">
  <div class="max-w-[1440px] mx-auto px-8 md:px-16 lg:px-24 w-full grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
    
    <!-- Left Content -->
    <div class="relative z-10 space-y-8 reveal">
      <div class="flex items-center gap-4">
        <span class="w-12 h-[1px] bg-primary"></span>
        <span class="text-[10px] uppercase tracking-[0.4em] text-primary font-medium">Carpintería, Persianas, Domótica y Decoración </span>
      </div>
      
      <h1 class="text-3xl sm:text-4xl md:text-6xl lg:text-7xl leading-[1.1] font-medium italic tracking-tight">
        Soluciones integrales <br/>
        <span class="text-primary not-italic">para cada rincón</span>
      </h1>
      
      <p class="max-w-md text-lg md:text-xl text-light-bg/70 font-light leading-relaxed">
        Especialistas en remodelación de interiores de alto impacto. Fusionamos la elegancia con acabados de lujo para crear hogares excepcionales.
      </p>
      
      <div class="flex flex-col sm:flex-row items-center gap-6 pt-4">
        <Button variant="primary" size="lg" href="#ambientes">
          Ver Proyectos
        </Button>
        <Button variant="ghost" size="lg" href="#proceso" className="group">
          Nuestro Proceso
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 ml-2 transition-transform group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
        </Button>
      </div>

      <!-- Stats Quick View (Keep static for now or fetch if needed) -->
      <div class="grid grid-cols-3 gap-8 pt-12 border-t border-white/10">
        <div>
          <p class="text-2xl font-serif">150+</p>
          <p class="text-[10px] uppercase tracking-widest text-light-bg/40">Proyectos</p>
        </div>
        <div>
          <p class="text-2xl font-serif">15</p>
          <p class="text-[10px] uppercase tracking-widest text-light-bg/40">Años Exp.</p>
        </div>
        <div>
          <p class="text-2xl font-serif">100%</p>
          <p class="text-[10px] uppercase tracking-widest text-light-bg/40">Calidad</p>
        </div>
      </div>
    </div>

    <!-- Right Image -->
    <div class="relative h-[60vh] lg:h-[80vh] reveal">
      <div class="absolute -inset-4 border border-white/5 translate-x-4 translate-y-4"></div>
      <div class="relative h-full w-full overflow-hidden">
        <img 
          src={getImageUrl(displayProject.image)} 
          alt={displayProject.title} 
          class="h-full w-full object-cover filter brightness-90 contrast-110 transition-transform duration-[2s] hover:scale-105"
        />
        <!-- Gradient Overlay -->
        <div class="absolute inset-0 bg-gradient-to-t from-dark-bg via-transparent to-transparent opacity-60"></div>
      </div>
      
      <div class="absolute -bottom-6 -left-6 bg-dark-section p-8 border border-white/10 hidden md:block">
        <p class="text-xs uppercase tracking-widest text-primary mb-2">Proyecto Destacado</p>
        <p class="text-xl font-serif">{displayProject.title} <br/> <span class="text-xs opacity-50">{displayProject.location}, {displayProject.city}, {displayProject.country}</span></p>
      </div>
    </div>

  </div>

  <!-- Animated Scroll Down -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 opacity-50">
    <span class="text-[10px] uppercase tracking-[0.5em] vertical-text">Scroll</span>
    <div class="w-[1px] h-12 bg-gradient-to-b from-primary to-transparent animate-bounce"></div>
  </div>
</section>

<style>
  .vertical-text {
    writing-mode: vertical-rl;
  }
