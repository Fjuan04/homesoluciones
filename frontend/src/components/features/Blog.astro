---
const posts = [
  {
    title: 'Tendencias en Cocinas Obsidian 2026',
    date: '24 Abril, 2026',
    cat: 'Diseño',
    excerpt: 'Descubre por qué el negro mate y la piedra natural dominan la arquitectura moderna este año.'
  },
  {
    title: 'Cómo Maximizar Espacios en Departamentos Luxury',
    date: '18 Abril, 2026',
    cat: 'Arquitectura',
    excerpt: 'Técnicas de curaduría para transformar áreas pequeñas en ambientes que respiran lujo.'
  },
  {
    title: 'Iluminación Inteligente: El Arte de Crear Escenas',
    date: '12 Abril, 2026',
    cat: 'Tecnología',
    excerpt: 'Guía técnica sobre la integración de sistemas domóticos en remodelaciones integrales.'
  }
];
---

<section id="blog" class="py-32 bg-dark-section border-y border-white/5">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-20 reveal">
      <div class="space-y-6">
        <h2 class="text-4xl md:text-6xl font-medium">Base de <span class="italic text-primary">Conocimiento</span></h2>
        <p class="text-light-bg/50 uppercase tracking-[0.3em] text-[10px]">Artículos técnicos y editoriales de diseño</p>
      </div>
      <a href="/blog" class="text-xs uppercase tracking-widest text-primary hover:opacity-70 transition-opacity flex items-center gap-2">
        Ver todo el blog
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {posts.map((post) => (
        <article class="reveal group cursor-pointer">
          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <span class="text-[10px] uppercase tracking-widest text-primary font-bold">{post.cat}</span>
              <span class="w-1 h-1 rounded-full bg-white/20"></span>
              <span class="text-[10px] uppercase tracking-widest text-light-bg/40">{post.date}</span>
            </div>
            
            <h3 class="text-2xl md:text-3xl font-serif text-white group-hover:text-primary transition-colors duration-300">
              {post.title}
            </h3>
            
            <p class="text-sm text-light-bg/50 leading-relaxed max-w-sm">
              {post.excerpt}
            </p>
            
            <div class="pt-4 overflow-hidden">
               <div class="h-[1px] w-full bg-white/10 relative">
                  <div class="absolute inset-0 bg-primary -translate-x-full group-hover:translate-x-0 transition-transform duration-500"></div>
               </div>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</section>
