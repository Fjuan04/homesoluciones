---
import Button from '../ui/Button.astro';

const API_URL = import.meta.env.API_URL || 'http://localhost:3000/api';

let services = [];

try {
  const response = await fetch(`${API_URL}/services`);
  if (response.ok) {
    services = await response.json();
  }
} catch (error) {
  console.error("Error fetching services:", error);
}

// Fallback
if (services.length === 0) {
  services = [
    { title: 'Remodelación Integral', desc: 'Transformación total de espacios residenciales con acabados de alta gama.', link: '#contacto' },
    { title: 'Diseño de Interiores', desc: 'Curaduría editorial para crear ambientes sofisticados y funcionales.', link: '#contacto' },
    { title: 'Arquitectura', desc: 'Línea exclusiva de diseño minimalista con texturas y materiales oscuros.', link: '#contacto' },
    { title: 'Gestión de Proyectos', desc: 'Supervisión técnica de principio a fin para garantizar resultados perfectos.', link: '#contacto' }
  ];
}
---

<section id="servicios" class="py-32 relative">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12">
    
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-20 reveal">
      <div class="space-y-6">
        <div class="flex items-center gap-4">
          <span class="w-12 h-[1px] bg-primary"></span>
          <span class="text-xs uppercase tracking-[0.4em] text-primary font-medium">Expertise</span>
        </div>
        <h2 class="text-4xl md:text-6xl font-medium">
          Servicios de Remodelación <br/> 
          <span class="italic text-primary">& Diseño</span>
        </h2>
      </div>
      <p class="max-w-md text-light-bg/60 leading-relaxed">
        Ofrecemos soluciones personalizadas para quienes buscan la excelencia en cada detalle. Desde el concepto inicial hasta la entrega final.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-px bg-white/10 border border-white/10">
      {services.map((service, index) => (
        <div class="bg-dark-bg p-10 space-y-8 flex flex-col justify-between group transition-colors duration-500 hover:bg-dark-section reveal">
          <div class="space-y-4">
            <span class="text-[10px] text-primary tracking-widest font-bold font-sans">0{index + 1}</span>
            <h3 class="text-2xl font-serif truncate" title={service.title}>
              {service.title}
            </h3>
            <p class="text-sm text-light-bg/50 leading-relaxed line-clamp-3" title={service.desc}>
              {service.desc}
            </p>
          </div>
          
          <a href={service.link} class="inline-flex items-center text-xs uppercase tracking-widest text-primary border-b border-primary/0 hover:border-primary/100 transition-all duration-300 w-fit pb-1">
            Saber Más
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 ml-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
          </a>
        </div>
      ))}
    </div>

    <div class="mt-20 text-center reveal">
      <Button variant="outline" size="lg" href="#contacto">
        Asesoría Personalizada
      </Button>
    </div>

  </div>
</section>
