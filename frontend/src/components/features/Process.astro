---
const steps = [
  {
    num: '01',
    title: 'Consultoría Especializada',
    desc: 'Entendemos tu visión y analizamos el potencial del espacio para definir la dirección del proyecto.'
  },
  {
    num: '02',
    title: 'Diseño & Planificación',
    desc: 'Creamos propuestas visuales y planos técnicos detallados con una selección de materiales premium.'
  },
  {
    num: '03',
    title: 'Ejecución de Obra',
    desc: 'Nuestro equipo especializado transforma el espacio bajo una supervisión técnica rigurosa.'
  },
  {
    num: '04',
    title: 'Entrega & Perfección',
    desc: 'Finalizamos con los últimos detalles decorativos y una entrega garantizada de alta calidad.'
  }
];
---

<section id="proceso" class="py-32 bg-dark-section border-y border-white/5">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12">
    
    <div class="text-center mb-24 reveal">
      <h2 class="text-4xl md:text-6xl font-medium mb-6">Nuestro <span class="italic text-primary">Método</span></h2>
      <p class="max-w-2xl mx-auto text-light-bg/60 uppercase tracking-widest text-xs">
        Un proceso estructurado para garantizar resultados excepcionales
      </p>
    </div>

    <div class="relative grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-20">
      <!-- Connection lines (desktop only) -->
      <div class="hidden lg:block absolute top-[15%] left-[10%] right-[10%] h-[1px] bg-gradient-to-r from-primary/0 via-primary/30 to-primary/0"></div>

      {steps.map((step) => (
        <div class="relative z-10 space-y-8 reveal">
          <div class="w-16 h-16 rounded-full bg-dark-bg border border-primary/40 flex items-center justify-center text-primary font-bold font-sans text-lg mx-auto lg:mx-0 shadow-xl shadow-primary/10">
            {step.num}
          </div>
          
          <div class="text-center lg:text-left space-y-4">
            <h3 class="text-2xl font-serif">{step.title}</h3>
            <p class="text-sm text-light-bg/50 leading-relaxed">
              {step.desc}
            </p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
