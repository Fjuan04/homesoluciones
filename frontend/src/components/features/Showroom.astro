---
const environments = [
  {
    title: 'Living Obsidian',
    category: 'Sala Estar',
    image: '/images/showroom/living.webp'
  },
  {
    title: 'Kitchen Minimal',
    category: 'Cocina Luxury',
    image: '/images/showroom/kitchen.webp'
  },
  {
    title: 'Spa Experience',
    category: 'Baño Principal',
    image: '/images/showroom/bathroom.webp'
  },
  {
    title: 'Nocturnal Suite',
    category: 'Habitación Master',
    image: '/images/showroom/bedroom.webp'
  }
];
---

<section id="ambientes" class="py-32 overflow-hidden bg-dark-bg">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 mb-16 reveal">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div class="space-y-4">
        <h2 class="text-4xl md:text-6xl font-medium">Ambientes <span class="italic text-primary">Curados</span></h2>
        <p class="text-light-bg/50 uppercase tracking-[0.3em] text-[10px]">Inspiración para tu próximo proyecto</p>
      </div>
      <div class="flex gap-4">
        <button id="prev-btn" class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center hover:bg-primary hover:border-primary transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button id="next-btn" class="w-12 h-12 rounded-full border border-white/10 flex items-center justify-center hover:bg-primary hover:border-primary transition-all duration-300">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"/></svg>
        </button>
      </div>
    </div>
  </div>

  <div id="showroom-container" class="flex gap-8 overflow-hidden lg:overflow-hidden max-lg:overflow-x-auto px-6 md:px-12 scrollbar-hide snap-x snap-mandatory pb-12 transition-all">
    {environments.map((item) => (
      <div class="min-w-[85vw] md:min-w-[45vw] lg:min-w-[30vw] aspect-[4/5] relative group snap-center overflow-hidden cursor-none reveal">
        <img 
          src={item.image} 
          alt={item.title} 
          class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-dark-bg via-transparent to-transparent opacity-80 transition-opacity duration-500 group-hover:opacity-90"></div>
        
        <div class="absolute bottom-10 left-10 space-y-2 transform transition-transform duration-500 group-hover:-translate-y-2">
          <p class="text-[10px] uppercase tracking-[0.4em] text-primary font-bold">{item.category}</p>
          <h3 class="text-3xl font-serif text-white">{item.title}</h3>
        </div>

        <!-- View Details Indicator -->
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
          <div class="w-20 h-20 rounded-full bg-primary/90 backdrop-blur-sm flex items-center justify-center text-[10px] uppercase tracking-widest font-bold">
            Ver más
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const container = document.getElementById('showroom-container');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');

  nextBtn?.addEventListener('click', () => {
    container?.scrollBy({ left: 400, behavior: 'smooth' });
  });

  prevBtn?.addEventListener('click', () => {
    container?.scrollBy({ left: -400, behavior: 'smooth' });
  });
</script>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
