---
interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  className?: string;
}

const { 
  variant = 'primary', 
  size = 'md', 
  href, 
  className = '', 
  ...rest 
} = Astro.props;

const variants = {
  primary: 'bg-primary text-white hover:brightness-110 shadow-lg shadow-primary/20',
  secondary: 'bg-dark-section text-light-bg hover:bg-dark-section/80',
  outline: 'border border-primary text-primary hover:bg-primary hover:text-white',
  ghost: 'text-light-bg/70 hover:text-light-bg hover:bg-white/5'
};

const sizes = {
  sm: 'px-4 py-2 text-xs',
  md: 'px-6 py-3 text-sm',
  lg: 'px-10 py-4 text-base'
};

const classes = `inline-flex items-center justify-center font-medium tracking-wider uppercase transition-all duration-300 ${variants[variant]} ${sizes[size]} ${className}`;

const Element = href ? 'a' : 'button';
---

<Element href={href} class={classes} {...rest}>
  <slot />
</Element>
